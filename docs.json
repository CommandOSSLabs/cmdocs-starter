{
  "$schema": "https://cmdocs.dev/schema/docs.json",
  "name": "My Documentation",
  "description": "Built with cmdocs",
  "theme": {
    "colors": {
      "primary": "#2563EB"
    },
    "darkMode": true,
    "breadcrumb": true
  },
  "seo": {
    "title": "My Documentation",
    "titleTemplate": "%s — My Docs",
    "description": "Documentation built with cmdocs"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "description": "Learn how to build docs with cmdocs",
        "icon": "BookOpen",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Guides",
            "pages": ["guides/writing-content", "guides/components"]
          }
        ]
      }
    ]
  },
  "navbar": {
    "title": "My Docs",
    "logo": {
      "light": "/logo-light.svg",
      "dark": "/logo-dark.svg",
      "display": "logo-only",
      "width": 120,
      "height": 30
    },
    "links": []
  },
  "footer": {
    "text": "Built with cmdocs",
    "copyright": "© 2026 My Company"
  }
}
